# ── Frontend ───────────────────────────────────────────────────────────────────
# Base URL of the backend API (used in production builds).
# In development, Vite proxies /api/* to localhost:4000 automatically — no need to set this.
# VITE_API_URL=https://api.your-domain.com

# ── Backend (linefire_extracted/backend/.env) ──────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# PORT=4000
